{
  "expo": {
    "name": "SatApp",
    "slug": "satApp",
    "scheme": "satapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.jguevaral.satapp",
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Permite que Papeleta Clara reconozca tu voz para convertirla en texto.",
        "NSMicrophoneUsageDescription": "Permite que Papeleta Clara use el microfono para transcribir tu consulta."
      }
    },
    "android": {
      "package": "com.jguevaral.satapp",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Permite que Papeleta Clara use el microfono para transcribir tu consulta.",
          "speechRecognitionPermission": "Permite que Papeleta Clara reconozca tu voz para convertirla en texto.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite que Papeleta Clara acceda a tus fotos para adjuntar una imagen de la papeleta."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#062A78",
          "image": "./assets/icon.png",
          "imageWidth": 300,
          "resizeMode": "contain"
        }
      ],
      "expo-document-picker",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/satApp"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dfc16541-aa5a-4923-bc79-21cc01c74327"
      }
    },
    "owner": "jguevaral"
  }
}
